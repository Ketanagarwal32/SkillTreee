datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String         @id @default(cuid())
  username       String         @unique
  email          String         @unique
  password       String
  createdAt      DateTime       @default(now())
  
  journalEntries JournalEntry[]
  attributes     Attribute[]
  memories       Memory[]
  arcs           Arc[]
}

model JournalEntry {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawText    String
  createdAt  DateTime    @default(now())
  
  reflection Reflection?
}

model Reflection {
  id                   String       @id @default(cuid())
  entryId              String       @unique
  entry                JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  aiResponse           String       // One-sentence Buddha response
  emotionalTheme       String       // Single word or short phrase
  reflectionParagraph  String?      // AI's deeper observation about the user
  createdAt            DateTime     @default(now())
}

enum AttributeStatus {
  ACTIVE
  STAGNANT
}

model Attribute {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String             // Dynamically generated by AI (e.g., "Digital Focus", "Physical Harmony")
  points    Int                @default(0)
  status    AttributeStatus    @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  
  history   AttributeHistory[]

  @@unique([userId, name])
}

model AttributeHistory {
  id          String    @id @default(cuid())
  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  delta       Int
  reason      String
  createdAt   DateTime  @default(now())
}

model Memory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary     String   // 3-4 lines distilling the emotional essence
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
}

model Arc {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}