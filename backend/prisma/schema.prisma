datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String         @id @default(cuid())
  username       String         @unique
  email          String         @unique
  password       String
  createdAt      DateTime       @default(now())
  
  sessions       Session[]
  journalEntries JournalEntry[]
  attributes     Attribute[]
  memories       Memory[]
  arcs           Arc[]
}

model Session {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime
  closedAt        DateTime?
  processed       Boolean        @default(false)
  reflectionCount Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  entries     JournalEntry[]
  memories    Memory[]
  history     AttributeHistory[]
  reflections Reflection[]

  @@unique([userId, date])
}

model JournalEntry {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId  String?
  session    Session?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  rawText    String
  createdAt  DateTime    @default(now())
}

model Reflection {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

model Attribute {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String             // Dynamically generated by AI (e.g., "Digital Focus", "Physical Harmony")
  value     Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  
  history   AttributeHistory[]

  @@unique([userId, name])
}

model AttributeHistory {
  id          String    @id @default(cuid())
  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  sessionId   String?
  session     Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  delta       Int
  createdAt   DateTime  @default(now())
}

model Memory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String?
  session     Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  arcId       String?
  arc         Arc?     @relation(fields: [arcId], references: [id], onDelete: SetNull)
  summary     String   // 3-4 lines distilling the emotional essence
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
}

model Arc {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  memories    Memory[]
}
